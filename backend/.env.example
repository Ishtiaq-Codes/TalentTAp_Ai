DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///db.sqlite3
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# The public-facing URL of your frontend (no trailing slash)
# Development:
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://talenttap.com

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# AI Keys
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# ---------------------------------------------------------------------------
# Stripe Configuration
# ---------------------------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Get from https://dashboard.stripe.com/webhooks after adding an endpoint
# Your webhook URL: https://yourdomain.com/api/v1/subscriptions/webhook/
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Pre-create a Product+Price in Stripe Dashboard and paste the
# Price ID here. If left blank, the backend generates pricing dynamically.
# STRIPE_PRO_PRICE_ID=price_...
